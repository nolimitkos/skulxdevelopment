local function GetThemeKeyPath(colorValue)
    for key, value in pairs(c) do
        if typeof(value) == "Color3" and value == colorValue then
            return {key}
        elseif typeof(value) == "table" then
            for subKey, subValue in pairs(value) do
                if typeof(subValue) == "Color3" and subValue == colorValue then
                    return {key, subKey}
                end
            end
        end
    end
    return nil
end

local function ResolveThemeColor(theme, path)
    local node = theme
    for i = 1, #path do
        node = node[path[i]]
    end
    return node
end

local function TrackThemedProperty(instance, property, path)
    table.insert(ThemedInstances, {
        instance = instance,
        property = property,
        path = path
    })
end

local function RetargetThemedProperty(instance, property, path)
    for _, entry in ipairs(ThemedInstances) do
        if entry.instance == instance and entry.property == property then
            entry.path = path
            return
        end
    end
    TrackThemedProperty(instance, property, path)
end

local function ApplyTheme(themeName)
    local theme = Themes[themeName]
    if not theme then return end

    c = theme
    currentThemeName = themeName

    for i = #ThemedInstances, 1, -1 do
        local entry = ThemedInstances[i]
        if entry.instance and entry.instance.Parent then
            entry.instance[entry.property] = ResolveThemeColor(theme, entry.path)
        else
            table.remove(ThemedInstances, i)
        end
    end
end

