        TextColor3 = c.TextDark,
        Text = "Season Time: 00:00:00",
        TextXAlignment = Enum.TextXAlignment.Left,
        BackgroundTransparency = 1,
        TextSize = textsize.Normal,
        Size = UDim2.new(1, 0, 0, 17),
        LayoutOrder = 2,
        Parent = infoCol
    })

    Connections["info_players"] = rs.Heartbeat:Connect(function()
        local count = #plr:GetPlayers()
        playersLabel.Text = "Players: " .. count
        local t = math.floor(tick())
        local h2 = math.floor(t / 3600) % 24
        local m2 = math.floor(t / 60) % 60
        local s2 = t % 60
        seasonLabel.Text = string.format("Season Time: %02d:%02d:%02d", h2, m2, s2)
    end)

    if #updates > 0 then
        Library._CreateContentSection(infoTab, "[ Update ]")

        for _, updateText in ipairs(updates) do
            CreateInstance("TextLabel", {
                Name = "UpdateEntry",
                Font = f.Regular,
                TextColor3 = c.TextDark,
                Text = "• " .. updateText,
                TextXAlignment = Enum.TextXAlignment.Left,
                TextWrapped = true,
                BackgroundTransparency = 1,
                TextSize = textsize.Normal,
                Size = UDim2.new(1, 0, 0, 0),
                AutomaticSize = Enum.AutomaticSize.Y,
                Parent = infoTab.content
            })
        end

        CreateInstance("Frame", {
            Name = "UpdateSpacer",
            BackgroundTransparency = 1,
            Size = UDim2.new(1, 0, 0, 6),
            Parent = infoTab.content
        })
    end

    return {
        SetGameName = function(_, name)
            infoCol:FindFirstChild("GameName").Text = name
        end,
        SetGameIcon = function(_, img)
            thumbImg.Image = img
        end,
        GetTab = function()
            return infoTab
        end
    }
end

return Library
