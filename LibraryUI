        AutomaticSize = Enum.AutomaticSize.Y,
        Parent = dualFrame
    })
    CreateListLayout(rightCol, 10, Enum.SortOrder.LayoutOrder)

    local function CreateColumn(column, defaultName)
        local methods = {}
        local currentFrame

        local function NewSubSection(sectionName)
            CreateInstance("TextLabel", {
                Name = "SectionLabel",
                Font = f.Regular,
                TextColor3 = c.TextDark,
                Text = sectionName,
                TextXAlignment = Enum.TextXAlignment.Left,
                BackgroundTransparency = 1,
                TextSize = 15,
                Size = UDim2.new(1, 0, 0, 20),
                Parent = column
            })

            currentFrame = CreateInstance("Frame", {
                Name = "SectionContent",
                BackgroundTransparency = 1,
                Size = UDim2.new(1, 0, 0, 0),
                AutomaticSize = Enum.AutomaticSize.Y,
                Parent = column
            })
            CreateListLayout(currentFrame, 6, Enum.SortOrder.LayoutOrder)
        end

        NewSubSection(defaultName)

        function methods:CreateSection(sectionName)
            NewSubSection(sectionName)
            return methods
        end
        function methods:CreateToggle(config)
            return Library._CreateToggle({content = currentFrame, _library = tab._library}, config)
        end
        function methods:CreateSlider(config)
            return Library._CreateSlider({content = currentFrame, _library = tab._library}, config)
        end
        function methods:CreateButton(config)
            return Library._CreateButton({content = currentFrame, _library = tab._library}, config)
        end
        function methods:CreateDropdown(config)
            return Library._CreateDropdown({content = currentFrame, _library = tab._library}, config)
        end
        function methods:CreateKeybind(config)
            return Library._CreateKeybind({content = currentFrame, _library = tab._library}, config, tab._library)
        end
        function methods:CreateColorPicker(config)
            return Library._CreateColorPicker({content = currentFrame, _library = tab._library}, config)
        end
        function methods:CreateTextBox(config)
            return Library._CreateTextBox({content = currentFrame, _library = tab._library}, config)
        end

        return methods
    end

    local leftMethods = CreateColumn(leftCol, leftName or "Left")
    local rightMethods = CreateColumn(rightCol, rightName or "Right")

    return leftMethods, rightMethods
end

