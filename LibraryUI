local COLOR_PROPERTIES = {
    BackgroundColor3 = true,
    TextColor3 = true,
    ImageColor3 = true,
    Color = true
}

local function CreateInstance(className, properties)
    local instance = Instance.new(className)
    local themePaths = properties.ThemePaths
    for property, value in pairs(properties) do
        if property ~= "Parent" and property ~= "ThemePaths" then
            instance[property] = value
            if COLOR_PROPERTIES[property] and typeof(value) == "Color3" then
                local explicitPath = themePaths and themePaths[property]
                local path = explicitPath or GetThemeKeyPath(value)
                if path then
                    TrackThemedProperty(instance, property, path)
                end
            end
        end
    end
    if properties.Parent then
        instance.Parent = properties.Parent
    end
    return instance
end

