end

local function EnsureConfigFolder()
    if isfolder and not isfolder("SkulxConfigs") then
        makefolder("SkulxConfigs")
    end
end

local function GetAvailableConfigs()
    local configs = {}
    if isfolder and listfiles then
        EnsureConfigFolder()
        local files = listfiles("SkulxConfigs")
        for _, file in ipairs(files) do
            local name = file:match("SkulxConfigs/(.+)%.json$") or file:match("AcrylicConfigs\\(.+)%.json$")
            if name then
                table.insert(configs, name)
            end
        end
    end
    return configs
end

local function SaveAutoLoadSettings(data)
    if not writefile then return end
    EnsureConfigFolder()
    pcall(function()
        writefile("SkulxConfigs/_autoload.json", hs:JSONEncode(data))
    end)
end

local function GetAutoLoadSettings()
    if not readfile or not isfile then return {enabled = false, config = "default"} end
    EnsureConfigFolder()
    local path = "SkulxConfigs/_autoload.json"
    if not isfile(path) then return {enabled = false, config = "default"} end
    local success, data = pcall(function()
        return hs:JSONDecode(readfile(path))
    end)
    if success and type(data) == "table" then
        return data
    end
    return {enabled = false, config = "default"}
end

