        Name = "OptionsScroll",
        BackgroundTransparency = 1,
        BorderSizePixel = 0,
        Position = UDim2.new(0, 0, 0, searchBoxHeight),
        Size = UDim2.new(1, 0, 1, -searchBoxHeight),
        CanvasSize = UDim2.new(0, 0, 0, #options * s.Dropdown.OptionHeight),
        ScrollBarThickness = 3,
        ScrollBarImageColor3 = Color3.fromRGB(60, 60, 60),
        ZIndex = 100,
        Parent = optionsContainer
    })
    CreateListLayout(optionsScroll, 0, Enum.SortOrder.LayoutOrder)

    local function UpdateSelectedText()
        if multiSelect then
            selectedLabel.Text = #selected > 0 and table.concat(selected, ", ") or "None"
        else
            selectedLabel.Text = tostring(selected)
        end
    end

    local function CreateOptionButton(option)
        local isSelected = multiSelect and table.find(selected, option) ~= nil

        local optionBtn = CreateInstance("TextButton", {
            Name = option,
            Font = f.Regular,
            TextColor3 = c.Text,
            Text = option,
            BackgroundColor3 = Color3.fromRGB(30, 30, 30),
            BackgroundTransparency = 1,
            BorderSizePixel = 0,
            TextSize = textsize.Small,
            TextXAlignment = Enum.TextXAlignment.Left,
            Size = UDim2.new(1, 0, 0, s.Dropdown.OptionHeight),
            ZIndex = 100,
            Parent = optionsScroll
        })

        CreateInstance("UIPadding", {
            PaddingLeft = UDim.new(0, 10),
            PaddingRight = UDim.new(0, 24),
            Parent = optionBtn
        })

        local checkDot = CreateInstance("Frame", {
            Name = "CheckDot",
            BackgroundColor3 = c.Accent,
            AnchorPoint = Vector2.new(1, 0.5),
            Position = UDim2.new(1, -8, 0.5, 0),
            Size = UDim2.new(0, 6, 0, 6),
            BorderSizePixel = 0,
            BackgroundTransparency = isSelected and 0 or 1,
            ZIndex = 101,
            Parent = optionBtn
        })
        CreateCorner(checkDot, 100)

        local function RefreshVisual()
            local sel = multiSelect and (table.find(selected, option) ~= nil) or (selected == option)
            checkDot.BackgroundTransparency = sel and 0 or 1
            optionBtn.TextColor3 = sel and c.Text or c.TextDark
        end
        RefreshVisual()

        optionBtn.MouseEnter:Connect(function()
            CreateTween(optionBtn, {BackgroundTransparency = 0.5}, animationspeed.Fast)
        end)

        optionBtn.MouseLeave:Connect(function()
            CreateTween(optionBtn, {BackgroundTransparency = 1}, animationspeed.Fast)
        end)

        optionBtn.MouseButton1Click:Connect(function()
            PlayClickSound()
            if multiSelect then
                local index = table.find(selected, option)
                if index then
                    table.remove(selected, index)
                else
                    table.insert(selected, option)
                end
                RefreshVisual()
                UpdateSelectedText()
                callback(selected)
            else
                selected = option
                for _, child in ipairs(optionsScroll:GetChildren()) do
                    if child:IsA("TextButton") then
                        local dot = child:FindFirstChild("CheckDot")
                        if dot then dot.BackgroundTransparency = 1 end
                        child.TextColor3 = c.TextDark
                    end
                end
                RefreshVisual()
                UpdateSelectedText()
                callback(selected)
                expanded = false
                optionsContainer.Visible = false
                CreateTween(arrow, {Rotation = 0}, animationspeed.Normal)
                frame.ZIndex = 1
            end
        end)

        return optionBtn
    end

    for _, option in ipairs(options) do
        CreateOptionButton(option)
    end

    local function FilterOptions(query)
        query = query:lower()
        local visibleCount = 0
        for _, child in ipairs(optionsScroll:GetChildren()) do
            if child:IsA("TextButton") then
                local matches = query == "" or child.Name:lower():find(query, 1, true) ~= nil
                child.Visible = matches
                if matches then
                    visibleCount = visibleCount + 1
                end
            end
        end
        optionsScroll.CanvasSize = UDim2.new(0, 0, 0, visibleCount * s.Dropdown.OptionHeight)
    end

    searchBox:GetPropertyChangedSignal("Text"):Connect(function()
        FilterOptions(searchBox.Text)
    end)

    local toggleBtn = CreateInstance("TextButton", {
        Name = "ToggleBtn",
        Text = "",
        BackgroundTransparency = 1,
        Size = UDim2.new(1, 0, 1, 0),
        ZIndex = 3,
        Parent = selectedDisplay
    })

    toggleBtn.MouseButton1Click:Connect(function()
        PlayClickSound()
        expanded = not expanded
        optionsContainer.Visible = expanded
        if expanded then
            searchBox.Text = ""
            FilterOptions("")
        end
        CreateTween(arrow, {Rotation = expanded and 180 or 0}, animationspeed.Normal)
        frame.ZIndex = expanded and 10 or 1
    end)

    local methods = {
        SetValue = function(_, value)
            if multiSelect and type(value) == "table" then
                selected = value
            elseif not multiSelect then
                selected = value
            end
            UpdateSelectedText()
            callback(selected)
        end,
        GetValue = function()
            return selected
        end,
        Refresh = function(_, newOptions)
            options = newOptions
            for _, child in ipairs(optionsScroll:GetChildren()) do
                if child:IsA("TextButton") then
                    child:Destroy()
                end
            end
            if multiSelect then
                for i = #selected, 1, -1 do
                    if not table.find(options, selected[i]) then
                        table.remove(selected, i)
                    end
                end
            else
                if not table.find(options, selected) then
                    selected = options[1] or ""
                end
            end
            UpdateSelectedText()
            for _, option in ipairs(options) do
                CreateOptionButton(option)
            end
            optionsScroll.CanvasSize = UDim2.new(0, 0, 0, #options * s.Dropdown.OptionHeight)
            local newTotalHeight = math.min(#options * s.Dropdown.OptionHeight, maxVisibleOptions * s.Dropdown.OptionHeight)
            optionsContainer.Size = UDim2.new(0, 135, 0, newTotalHeight)
        end
    }

    if flag and tab._library then
        tab._library:_RegisterConfigElement(flag, "Dropdown", 
            function() return selected end,
            function(value) methods:SetValue(value) end
        )
    end

    return methods
end

